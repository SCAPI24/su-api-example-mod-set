<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PakExplorer.ViewModels"
        x:Class="PakExplorer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1100" Height="700" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <Style Selector="TreeViewItem:selected /template/ Border#BackgroundBorder">
      <Setter Property="Background" Value="#1a73e8"/>
    </Style>
  </Window.Styles>

  <DockPanel Name="MainPanel">
    <!-- 菜单栏 -->
    <Menu DockPanel.Dock="Top" Name="MainMenu">
      <MenuItem Header="文件(_F)" Name="MenuFile">
        <MenuItem Header="新建PAK...(_N)" Name="MenuFileNewPak" Click="OnNewPak" InputGesture="Ctrl+N"/>
        <MenuItem Header="打开PAK...(_O)" Name="MenuFileOpenPak" Click="OnOpenPak" InputGesture="Ctrl+O"/>
        <MenuItem Header="关闭(_C)" Name="MenuFileClose" Click="OnClosePak" InputGesture="Ctrl+W"/>
        <Separator/>
        <MenuItem Header="保存修改...(_S)" Name="MenuFileSave" Click="OnSavePak" InputGesture="Ctrl+S"/>
        <Separator/>
        <MenuItem Header="退出(_X)" Name="MenuFileExit" Click="OnExit" InputGesture="Alt+F4"/>
      </MenuItem>
      <MenuItem Header="操作(_A)" Name="MenuAction">
        <MenuItem Header="提取选中...(_E)" Name="MenuActionExtractSel" Click="OnExtractSelected" InputGesture="Ctrl+E"/>
        <MenuItem Header="提取当前文件夹...(_F)" Name="MenuActionExtractFolder" Click="OnExtractFolder"/>
        <MenuItem Header="提取全部...(_A)" Name="MenuActionExtractAll" Click="OnExtractAll"/>
        <Separator/>
        <MenuItem Header="导入替换选中...(_I)" Name="MenuActionImport" Click="OnImport" InputGesture="Ctrl+I"/>
        <Separator/>
        <MenuItem Header="撤销选中修改(_R)" Name="MenuActionRevertSel" Click="OnRevertSelected"/>
        <MenuItem Header="撤销全部修改(_V)" Name="MenuActionRevertAll" Click="OnRevertAll"/>
      </MenuItem>
      <MenuItem Header="视图(_V)" Name="MenuView">
        <MenuItem Header="统计信息(_S)" Name="MenuViewStats" Click="OnStatistics"/>
      </MenuItem>
      <MenuItem Header="{Binding MenuPreferences}" Name="MenuPreferencesItem">
        <MenuItem Header="Language" Name="MenuLanguageItem"/>
      </MenuItem>
    </Menu>

    <!-- 工具栏 -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2" Spacing="4">
      <Button Content="打开" Name="BtnOpen" Click="OnOpenPak" Margin="0,0,4,0"/>
      <Button Content="提取" Name="BtnExtract" Click="OnExtractSelected" Margin="0,0,4,0"/>
      <Button Content="导入" Name="BtnImport" Click="OnImport" Margin="0,0,4,0"/>
      <Button Content="保存" Name="BtnSave" Click="OnSavePak" Margin="0,0,4,0"/>
      <Separator Margin="4,0"/>
      <TextBox Width="200" Name="SearchBox" Watermark="搜索条目..." Text="{Binding SearchKeyword}"
              KeyDown="OnSearchKeyDown"/>
      <Button Content="搜索" Name="BtnSearch" Click="OnSearch"/>
      <Button Content="清除" Name="BtnClear" Click="OnClearSearch"/>
    </StackPanel>

    <!-- 状态栏 -->
    <Border DockPanel.Dock="Bottom" Background="#1e1e1e" Padding="8,4">
      <TextBlock Text="{Binding StatusText}" Foreground="#cccccc" FontSize="12"/>
    </Border>

    <!-- 主体内容 -->
    <Grid ColumnDefinitions="250,Auto,*" RowDefinitions="*,Auto">
      <!-- 左侧文件夹树 -->
      <TreeView Grid.Column="0" Name="FolderTree" ItemsSource="{Binding RootNodes}"
                SelectionChanged="OnFolderSelectionChanged"
                PointerPressed="OnTreePointerPressed"
                KeyDown="OnTreeKeyDown"
                Margin="0,0,2,0">
        <TreeView.ContextMenu>
          <ContextMenu>
            <MenuItem Header="新建文件夹" Name="CtxNewFolder" Click="OnTreeNewFolder"/>
            <MenuItem Header="新建文件" Name="CtxNewFile" Click="OnTreeNewFile"/>
            <Separator/>
            <MenuItem Header="复制文件夹" Name="CtxCopyFolder" Click="OnTreeCopyFolder" InputGesture="Ctrl+C"/>
            <MenuItem Header="剪切文件夹" Name="CtxCutFolder" Click="OnTreeCutFolder" InputGesture="Ctrl+X"/>
            <MenuItem Header="粘贴到此文件夹" Name="CtxPasteFolder" Click="OnTreePasteFolder" InputGesture="Ctrl+V" IsEnabled="{Binding CanPaste}"/>
            <Separator/>
            <MenuItem Header="删除文件夹" Name="CtxDeleteFolder" Click="OnTreeDeleteFolder" InputGesture="Delete"/>
            <Separator/>
            <MenuItem Header="提取文件夹..." Name="CtxExtractFolder" Click="OnExtractFolder"/>
          </ContextMenu>
        </TreeView.ContextMenu>
        <TreeView.ItemTemplate>
          <TreeDataTemplate ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#x1F4C1;" FontSize="14"/>
              <TextBlock Text="{Binding Name}"/>
            </StackPanel>
          </TreeDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>

      <!-- 分割线 -->
      <GridSplitter Grid.Column="1" Width="4" ResizeBehavior="PreviousAndNext"/>

      <!-- 右侧区域 -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*" Name="RightPanel"
            Background="White"
            PointerPressed="OnRightPanelPointerPressed">
        <!-- 工具栏 -->
        <Border Grid.Row="0" BorderBrush="#ddd" BorderThickness="0,0,0,1" Padding="8,4">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Name="BtnCut"     Content="✂️" FontSize="14" IsEnabled="{Binding HasSelectedEntry}" Click="OnToolCut" PointerEntered="OnToolPointerEntered" PointerExited="OnToolPointerExited" Tag="剪切" Background="Transparent" BorderThickness="0" Padding="2" VerticalAlignment="Center"/>
            <Button Name="BtnCopy"    Content="📋" FontSize="14" IsEnabled="{Binding HasSelectedEntry}" Click="OnToolCopy" PointerEntered="OnToolPointerEntered" PointerExited="OnToolPointerExited" Tag="复制" Background="Transparent" BorderThickness="0" Padding="2" VerticalAlignment="Center"/>
            <Button Name="BtnPaste"   Content="📌" FontSize="14" IsEnabled="{Binding CanPaste}"        Click="OnToolPaste" PointerEntered="OnToolPointerEntered" PointerExited="OnToolPointerExited" Tag="粘贴" Background="Transparent" BorderThickness="0" Padding="2" VerticalAlignment="Center"/>
            <Button Name="BtnRename"  Content="✏️" FontSize="14" IsEnabled="{Binding HasSelectedEntry}" Click="OnToolRename" PointerEntered="OnToolPointerEntered" PointerExited="OnToolPointerExited" Tag="重命名" Background="Transparent" BorderThickness="0" Padding="2" VerticalAlignment="Center"/>
            <Button Name="BtnExport"   Content="📤" FontSize="14" IsEnabled="{Binding HasSelectedEntry}" Click="OnToolExport" PointerEntered="OnToolPointerEntered" PointerExited="OnToolPointerExited" Tag="导出" Background="Transparent" BorderThickness="0" Padding="2" VerticalAlignment="Center"/>
            <Button Name="BtnDelete"   Content="🗑️" FontSize="14" IsEnabled="{Binding HasSelectedEntry}" Click="OnToolDelete" PointerEntered="OnToolPointerEntered" PointerExited="OnToolPointerExited" Tag="删除" Background="Transparent" BorderThickness="0" Padding="2" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- 文件列表 DataGrid -->
        <DataGrid Grid.Row="1" Name="EntryGrid" ItemsSource="{Binding CurrentFiles}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserSortColumns="True" SelectionMode="Extended"
                  CanUserResizeColumns="True"
                  HorizontalScrollBarVisibility="Auto"
                  SelectionChanged="OnEntrySelectionChanged"
                  DoubleTapped="OnEntryDoubleTapped"
                  KeyDown="OnGridKeyDown">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="名称" Width="200" SortMemberPath="SortName">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="类型" Binding="{Binding TypeName}" Width="SizeToHeader"/>
            <DataGridTextColumn Header="扩展名" Binding="{Binding Extension}" Width="SizeToHeader"/>
            <DataGridTextColumn Header="大小" Binding="{Binding SizeFormatted}" Width="SizeToHeader"/>
            <DataGridCheckBoxColumn Header="已修改" Binding="{Binding IsModified}" Width="SizeToHeader"/>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
